{
  "name": "student-management-backend",
  "version": "1.0.0",
  "description": "Student Management System Backend",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "predev": "prisma generate",
    "dev": "tsx watch src/index.ts",
    "prebuild": "prisma generate",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev && prisma generate",
    "db:migrate:prod": "prisma migrate deploy && prisma generate",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.3",
    "prisma": "^7.8.0",
    "tsx": "^4.19.4",
    "typescript": "^6.0.3"
  }
}
